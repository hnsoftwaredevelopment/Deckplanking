<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:DeckPlanking.App.Localization"
             x:Class="DeckPlanking.App.UserGuidePage"
             Title="{loc:Translate UserGuideTitle}"
             BackgroundColor="{DynamicResource AppBackgroundColor}">

    <Grid RowDefinitions="Auto,*">
        <Border Padding="16,12"
                Stroke="{DynamicResource AppAccentColor}"
                StrokeThickness="1"
                BackgroundColor="{DynamicResource AppSurfaceColor}">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <Label Text="{loc:Translate UserGuideTitle}"
                       FontAttributes="Bold"
                       FontSize="20"
                       VerticalOptions="Center"
                       TextColor="{DynamicResource AppPrimaryTextColor}" />
                <Button Grid.Column="1"
                        Text="{loc:Translate Close}"
                        Clicked="OnCloseClicked"
                        ToolTipProperties.Text="{loc:Translate Close}"
                        SemanticProperties.Description="{loc:Translate Close}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <WebView x:Name="GuideWebView" />
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="True"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Color="{DynamicResource AppAccentColor}" />
        </Grid>
    </Grid>
</ContentPage>
