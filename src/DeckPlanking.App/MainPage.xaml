<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DeckPlanking.App.MainPage">

    <ScrollView BackgroundColor="{StaticResource AppBackgroundColor}">
        <Grid Padding="24"
              RowDefinitions="Auto,Auto"
              RowSpacing="18"
              MaximumWidthRequest="980">
            <VerticalStackLayout Spacing="6">
                <Label Text="Modelboat Deckplanking"
                       Style="{StaticResource Headline}"
                       TextColor="{StaticResource AppPrimaryTextColor}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Label Text="Scale a full-size plank and prepare the cut length for the selected butt-shift pattern."
                       Style="{StaticResource SubHeadline}"
                       TextColor="{StaticResource AppSecondaryTextColor}"
                       SemanticProperties.HeadingLevel="Level2" />
            </VerticalStackLayout>

            <Grid Grid.Row="1"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="16">
                <Border Padding="16"
                        Stroke="{StaticResource AppAccentColor}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource AppSurfaceColor}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Inputs"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{StaticResource AppPrimaryTextColor}" />

                        <Grid ColumnDefinitions="220,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="14"
                              RowSpacing="8">
                            <Label Text="Full-size plank length"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Entry Grid.Column="1"
                                   Text="{Binding RealPlankLength, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   ClearButtonVisibility="WhileEditing" />

                            <Label Grid.Row="1"
                                   Text="Length unit"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Picker Grid.Row="1"
                                    Grid.Column="1"
                                    Title="Length unit"
                                    ItemsSource="{Binding LengthUnits}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedLengthUnit}" />

                            <Label Grid.Row="2"
                                   Text="Scale mode"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Picker Grid.Row="2"
                                    Grid.Column="1"
                                    Title="Scale mode"
                                    ItemsSource="{Binding ScaleModes}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedScaleMode}" />

                            <Label Grid.Row="3"
                                   Text="Scale 1:N"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding IsDecimalScale}"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Entry Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding DecimalScale, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   IsVisible="{Binding IsDecimalScale}"
                                   ClearButtonVisibility="WhileEditing" />

                            <Label Grid.Row="3"
                                   Text="Inches per real foot"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding IsImperialScale}"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Entry Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding ImperialInchesPerFoot, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   IsVisible="{Binding IsImperialScale}"
                                   ClearButtonVisibility="WhileEditing" />

                            <Label Grid.Row="4"
                                   Text="Shift pattern"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Picker Grid.Row="4"
                                    Grid.Column="1"
                                    Title="Shift pattern"
                                    ItemsSource="{Binding Patterns}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedPattern}" />
                        </Grid>

                        <Label Text="{Binding ValidationMessage}"
                               TextColor="#B3261E" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1"
                        Padding="16"
                        Stroke="{StaticResource AppAccentColor}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource AppSurfaceColor}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Calculated plank length"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{StaticResource AppPrimaryTextColor}" />

                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              RowSpacing="12">
                            <Label Text="Raw scale length"
                                   TextColor="{StaticResource AppSecondaryTextColor}" />
                            <Label Grid.Column="1"
                                   Text="{Binding RawScaleLengthText}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />

                            <Label Grid.Row="1"
                                   Text="Cut length"
                                   TextColor="{StaticResource AppSecondaryTextColor}" />
                            <Label Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding CutLengthText}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />

                            <Label Grid.Row="2"
                                   Text="Segment length"
                                   TextColor="{StaticResource AppSecondaryTextColor}" />
                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding SegmentLengthText}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />

                            <Label Grid.Row="3"
                                   Text="Imperial display"
                                   TextColor="{StaticResource AppSecondaryTextColor}" />
                            <Label Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding ImperialDisplayText}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>
