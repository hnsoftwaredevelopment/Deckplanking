<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DeckPlanking.App.MainPage">

    <ScrollView BackgroundColor="{StaticResource AppBackgroundColor}">
        <Grid Padding="24"
              RowDefinitions="Auto,Auto"
              RowSpacing="18"
              MaximumWidthRequest="980">
            <VerticalStackLayout Spacing="6">
                <Label Text="Modelboat Deckplanking"
                       Style="{StaticResource Headline}"
                       TextColor="{StaticResource AppPrimaryTextColor}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Label Text="Scale a full-size plank and prepare the cut length for the selected butt-shift pattern."
                       Style="{StaticResource SubHeadline}"
                       TextColor="{StaticResource AppSecondaryTextColor}"
                       SemanticProperties.HeadingLevel="Level2" />
            </VerticalStackLayout>

            <Grid Grid.Row="1"
                  RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="16">
                <Border Padding="16"
                        Stroke="{StaticResource AppAccentColor}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource AppSurfaceColor}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Inputs"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{StaticResource AppPrimaryTextColor}" />

                        <Grid ColumnDefinitions="220,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="14"
                              RowSpacing="8">
                            <Label Text="Full-size plank length"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Entry Grid.Column="1"
                                   Text="{Binding RealPlankLength, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   ClearButtonVisibility="WhileEditing" />

                            <Label Grid.Row="1"
                                   Text="Length unit"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Picker Grid.Row="1"
                                    Grid.Column="1"
                                    ItemsSource="{Binding LengthUnits}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedLengthUnit}" />

                            <Label Grid.Row="2"
                                   Text="Scale mode"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Picker Grid.Row="2"
                                    Grid.Column="1"
                                    ItemsSource="{Binding ScaleModes}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedScaleMode}" />

                            <Label Grid.Row="3"
                                   Text="Scale 1:N"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding IsDecimalScale}"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Entry Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding DecimalScale, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   IsVisible="{Binding IsDecimalScale}"
                                   ClearButtonVisibility="WhileEditing" />

                            <Label Grid.Row="3"
                                   Text="Inches per real foot"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding IsImperialScale}"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Entry Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding ImperialInchesPerFoot, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   IsVisible="{Binding IsImperialScale}"
                                   ClearButtonVisibility="WhileEditing" />

                            <Label Grid.Row="4"
                                   Text="Deck length"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Entry Grid.Row="4"
                                   Grid.Column="1"
                                   Text="{Binding DeckLengthMillimeters, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   ClearButtonVisibility="WhileEditing" />

                            <Label Grid.Row="5"
                                   Text="Rows"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Entry Grid.Row="5"
                                   Grid.Column="1"
                                   Text="{Binding RowCount, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   ClearButtonVisibility="WhileEditing" />

                            <Label Grid.Row="6"
                                   Text="Start point"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Entry Grid.Row="6"
                                   Grid.Column="1"
                                   Text="{Binding StartPoint, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   ClearButtonVisibility="WhileEditing" />

                            <Label Grid.Row="7"
                                   Text="Shift pattern"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                            <Picker Grid.Row="7"
                                    Grid.Column="1"
                                    ItemsSource="{Binding Patterns}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedPattern}" />
                        </Grid>

                        <Label Text="{Binding ValidationMessage}"
                               TextColor="#B3261E" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1"
                        Padding="16"
                        Stroke="{StaticResource AppAccentColor}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource AppSurfaceColor}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Calculated plank length"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{StaticResource AppPrimaryTextColor}" />

                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="12">
                            <Label Text="Cut length"
                                   TextColor="{StaticResource AppSecondaryTextColor}" />
                            <Label Grid.Column="1"
                                   Text="{Binding CutLengthText}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />

                            <Label Grid.Row="1"
                                   Text="Segment length"
                                   TextColor="{StaticResource AppSecondaryTextColor}" />
                            <Label Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding SegmentLengthText}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AppPrimaryTextColor}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2"
                        Padding="16"
                        Stroke="{StaticResource AppAccentColor}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource AppSurfaceColor}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Pattern preview"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{StaticResource AppPrimaryTextColor}" />

                        <FlexLayout Direction="Row"
                                    Wrap="Wrap"
                                    AlignItems="Center"
                                    JustifyContent="Start">
                            <Button Text="-"
                                    Clicked="OnZoomOutClicked"
                                    MinimumWidthRequest="40"
                                    MinimumHeightRequest="36"
                                    Padding="0"
                                    Margin="0,0,6,6" />
                            <Button Text="+"
                                    Clicked="OnZoomInClicked"
                                    MinimumWidthRequest="40"
                                    MinimumHeightRequest="36"
                                    Padding="0"
                                    Margin="0,0,6,6" />
                            <Button Text="Reset"
                                    Clicked="OnResetViewportClicked"
                                    MinimumHeightRequest="36"
                                    Padding="12,0"
                                    Margin="0,0,10,6" />
                            <HorizontalStackLayout Spacing="6"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,10,6">
                                <Label Text="King plank"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource AppPrimaryTextColor}" />
                                <Switch IsToggled="{Binding UseKingPlank, Mode=TwoWay}"
                                        VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,10,6">
                                <Label Text="Trenails"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource AppPrimaryTextColor}" />
                                <Switch IsToggled="{Binding ShowTrenails, Mode=TwoWay}"
                                        VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,0,6">
                                <Label Text="Orientation"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource AppPrimaryTextColor}" />
                                <Picker ItemsSource="{Binding DeckOrientations}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        SelectedItem="{Binding SelectedDeckOrientation}"
                                        WidthRequest="116"
                                        VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </FlexLayout>

                        <Border Padding="0"
                                Stroke="{StaticResource AppAccentColor}"
                                StrokeThickness="1"
                                HeightRequest="340"
                                BackgroundColor="#FFF7EC">
                            <GraphicsView x:Name="PatternGraphics"
                                          HeightRequest="340">
                                <GraphicsView.GestureRecognizers>
                                    <PanGestureRecognizer PanUpdated="OnPatternPanUpdated" />
                                    <PinchGestureRecognizer PinchUpdated="OnPatternPinchUpdated" />
                                </GraphicsView.GestureRecognizers>
                            </GraphicsView>
                        </Border>

                        <Button Text="{Binding SeamTableToggleText}"
                                Command="{Binding ToggleSeamTableCommand}"
                                HorizontalOptions="Start"
                                Padding="12,8"
                                MinimumHeightRequest="36" />

                        <Grid ColumnDefinitions="70,90,*"
                              ColumnSpacing="10"
                              IsVisible="{Binding IsSeamTableVisible}">
                            <Label Text="Row"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AppSecondaryTextColor}" />
                            <Label Grid.Column="1"
                                   Text="Offset"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AppSecondaryTextColor}" />
                            <Label Grid.Column="2"
                                   Text="Seams (mm)"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AppSecondaryTextColor}" />
                        </Grid>

                        <CollectionView ItemsSource="{Binding PatternRows}"
                                        HeightRequest="220"
                                        IsVisible="{Binding IsSeamTableVisible}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="70,90,*"
                                          ColumnSpacing="10"
                                          Padding="0,4">
                                        <Label Text="{Binding RowNumber}"
                                               TextColor="{StaticResource AppPrimaryTextColor}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding SeamOffsetSegments}"
                                               TextColor="{StaticResource AppPrimaryTextColor}" />
                                        <Label Grid.Column="2"
                                               Text="{Binding SeamPositionsText}"
                                               LineBreakMode="TailTruncation"
                                               TextColor="{StaticResource AppPrimaryTextColor}" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>
